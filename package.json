{
  "name": "buildos-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "BuildOS: idea to app, automatically.",
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "test:api": "cd apps/api && pytest",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "workspaces": [
    "apps/web"
  ],
  "overrides": {
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}

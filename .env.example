# Shared local development settings. Copy to .env and fill only the values you need.
POSTGRES_DB=buildos
POSTGRES_USER=buildos
POSTGRES_PASSWORD=buildos_dev_password
DATABASE_URL=postgresql+psycopg://buildos:buildos_dev_password@postgres:5432/buildos
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace-with-a-long-random-local-secret
AI_PROVIDER=local
GEMINI_API_KEY=
OPENAI_API_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=
ENCRYPTION_KEY=replace-with-32-byte-dev-key
APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=BuildOS
